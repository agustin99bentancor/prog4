#include "Alojamiento.h"

// Constructor con lista de inicialización de la base
Alojamiento::Alojamiento(string codigoReserva, string descripcion, int precioBase, DTFecha fecha,
                         string hotel, TipoRegimen regimen, int cantNoches)
    : Experiencia(codigoReserva, descripcion, precioBase, fecha) 
{
    this->hotel = hotel;
    this->regimen = regimen;
    this->cantNoches = cantNoches;
}

// calcularCosto según el enunciado
float Alojamiento::calcularCosto() {
    // Accedemos directamente a precioBase porque está protegido en Experiencia
    float costo = precioBase * cantNoches;

    // Agregamos 10 unidades por noche si es AllInclusive
    if (regimen == AllInclusive) {
        costo += 10 * cantNoches;
    }

    return costo;
}

// Getters
string Alojamiento::getHotel() {
    return hotel;
}

TipoRegimen Alojamiento::getRegimen() {
    return regimen;
}

int Alojamiento::getCantNoches() {
    return cantNoches;
}
